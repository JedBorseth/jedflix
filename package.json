{
  "name": "jedflix",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:backend dev:stream",
    "dev:mobile": "turbo run dev --filter=@jedflix/mobile",
    "dev:backend": "convex dev",
    "dev:stream": "turbo run dev --filter=@jedflix/stream-server",
    "predev": "convex dev --until-success && node setup.mjs --once && convex dashboard",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "preview": "turbo run preview --filter=@jedflix/web"
  },
  "devDependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.77",
    "@jedflix/shared": "workspace:*",
    "convex": "^1.17.0",
    "dotenv": "^16.4.5",
    "npm-run-all": "^4.1.5",
    "prettier": "3.3.2",
    "turbo": "^2.5.4"
  },
  "overrides": {
    "react-native": "0.81.5"
  }
}
