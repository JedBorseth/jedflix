# Public site domain (must resolve to this server for Caddy SSL)
DOMAIN=borseth.ddns.net
ACME_EMAIL=you@example.com

# Optional basic auth in front of the whole site (generate hash with `caddy hash-password`)
BASIC_AUTH_USER=borseth
BASIC_AUTH_HASH=

# Convex (from .env.local after `convex dev` / `convex deploy`)
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional: used by GitHub Actions or manual deploy scripts on the server
# CONVEX_DEPLOY_KEY=

# TMDB
VITE_TMDB_API_KEY=

# Stream API (frontend uses same-origin /stream-api via Caddy)
VITE_STREAM_API_URL=/stream-api
VITE_STREAM_API_KEY=

# Go stream-server
REALDEBRID_TOKEN=
PROXY_SIGNING_SECRET=
STREAM_SERVER_API_KEY=
CORS_ORIGINS=https://borseth.ddns.net
RD_BLOCKED_FILENAME_REGEX=web-dl|webrip|bdrip|hdrip|dvdrip|BluRay\.x264|HDTV\.x264|HDTV\.XviD|WEB\.x264|WEB\.h264
