# Copy to deploy/.env.production on the production server.
# Used by scripts/deploy-production.sh for manual or server-side deploys.
#
# GitHub Actions uses repository secrets/variables instead of this file.

# Required for Convex deploy + frontend build
CONVEX_DEPLOY_KEY=

# Required for TMDB API calls in the frontend
VITE_TMDB_API_KEY=

# Frontend stream API settings
# Use /stream-api when nginx/caddy proxies to the Go service on :8080
VITE_STREAM_API_URL=/stream-api
VITE_STREAM_API_KEY=

# Optional override for where static files are copied
# PROD_WEB_ROOT=/var/www/jedflix
